{
  "name": "react-perf-scan",
  "version": "0.1.1",
  "description": "Dev-only wasted-render visualizer and memoization advisor for React 18 & 19",
  "author": "rzkyerl",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "react",
    "performance",
    "devtools",
    "profiler",
    "wasted-render",
    "memo",
    "useMemo",
    "useCallback",
    "react-18",
    "react-19",
    "typescript",
    "debugging"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rzkyerl/react-perf-scan.git",
    "directory": "packages/react-perf-scan"
  },
  "homepage": "https://github.com/rzkyerl/react-perf-scan#readme",
  "bugs": {
    "url": "https://github.com/rzkyerl/react-perf-scan/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.dev.cjs",
  "module": "./dist/index.dev.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": {
        "import": "./dist/index.dev.mjs",
        "require": "./dist/index.dev.cjs"
      },
      "production": {
        "import": "./dist/index.prod.mjs",
        "require": "./dist/index.prod.cjs"
      },
      "import": "./dist/index.prod.mjs",
      "require": "./dist/index.prod.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "size:report": "node ./scripts/report-bundle-size.mjs",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build && node -e \"const fs=require('fs'); ['README.md','CHANGELOG.md','LICENSE'].forEach(f=>fs.copyFileSync('../../'+f,f))\""
  }
}
